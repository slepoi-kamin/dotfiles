# command = /bin/zsh -l -c "tmux new -A -s backend"

# Font
font-family = JetBrainsMono Nerd Font
font-style = SemiBold
font-size = 13

# Theme
theme = "Catppuccin Mocha"
background-opacity = 0.9
background-blur-radius = 20

# Cursor
cursor-invert-fg-bg

# Mouse
mouse-hide-while-typing
mouse-hide-while-typing = true

# Window
window-padding-balance = true
window-save-state = always

macos-option-as-alt = true
quit-after-last-window-closed = true
gtk-single-instance = true

# Keybinds
# keybind = cmd+t=text:\x06c
# keybind = cmd+w=text:\x06x
# keybind = cmd+d=text:\x06%
# keybind = cmd+shift+d=text:\x06\"

# tmux-style pane navigation
# keybind = alt+left=goto_split:left
# keybind = alt+right=goto_split:right
# keybind = alt+up=goto_split:up
# keybind = alt+down=goto_split:down
